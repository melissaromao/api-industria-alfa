# Copie este arquivo para .env e preencha os valores
# O .env real nunca deve ser enviado ao GitHub

# Porta do servidor (o Render define isso automaticamente)
PORT=8080

# Usuários da API em formato JSON
# Roles disponíveis: admin, operator
# admin  -> pode ler sensores, enviar comandos, atualizar firmware
# operator -> pode apenas ler sensores
API_USERS={"gestor": {"password": "troque-essa-senha", "role": "admin"}, "operador": {"password": "troque-essa-senha", "role": "operator"}}
